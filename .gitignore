#   For a library or package, you might want to ignore these files since the values are
#   specific to the developer's system of choice.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used with a venv, it may be ignored.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is generally recommended to be committed.
#poetry.lock

