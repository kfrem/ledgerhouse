# --- Django ---
# Production: DEBUG must be False and SECRET_KEY is then REQUIRED.
# Generate a key:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DEBUG=False
SECRET_KEY=
ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated origins, e.g. https://ledger.example.com
CSRF_TRUSTED_ORIGINS=
# Set to True once HTTPS is terminated in front of the app (enables SSL
# redirect, secure cookies and HSTS).
SECURE_TLS=False

# --- Database (PostgreSQL is mandatory) ---
POSTGRES_DB=ledgerhouse_db
POSTGRES_USER=ledgerhouse_user
POSTGRES_PASSWORD=
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Restricted application role (production; see deploy/create_app_role.sql) ---
# Leave blank on first boot; after creating the role, set these and restart
# so the web app connects without superuser/BYPASSRLS privileges.
APP_DB_USER=
APP_DB_PASSWORD=

# --- HMRC Developer Hub / VAT MTD sandbox ---
# Main sandbox app currently configured in HMRC Developer Hub:
# KAFS UK Accounting SaaS, redirect URI:
# http://localhost:8000/api/integrations/hmrc/callback
HMRC_ENVIRONMENT=sandbox
HMRC_CLIENT_ID=
HMRC_CLIENT_SECRET=
HMRC_REDIRECT_URI=http://localhost:8000/api/integrations/hmrc/callback
HMRC_SCOPES=read:vat write:vat
HMRC_API_BASE_URL=https://test-api.service.hmrc.gov.uk
